<style>
:root{--dark:#1E1410;--dark2:#2A1C14;--gold:#C9A96E;--gold-lt:#E8D5A3;--sand:#D4C4B0;--white:#FDFAF6}
*{box-sizing:border-box}
body{margin:0;background:var(--dark);color:var(--sand);font-family:Georgia,"Times New Roman",serif;line-height:1.7}
.wrap{max-width:760px;margin:0 auto;padding:3.5rem 1.5rem 5rem}
.eyebrow{font-family:system-ui,sans-serif;letter-spacing:.18em;text-transform:uppercase;font-size:.72rem;color:var(--gold);opacity:.85}
h1{color:var(--white);font-size:clamp(2rem,5vw,2.8rem);font-weight:500;margin:.4rem 0 .3rem}
h2{color:var(--gold-lt);font-size:1.3rem;font-weight:500;margin:2.2rem 0 .6rem}
p,li{font-size:1.05rem}
a{color:var(--gold-lt)}
.upd{font-family:system-ui,sans-serif;font-size:.85rem;color:var(--sand);opacity:.6;margin-bottom:2rem}
.back{display:inline-block;margin-top:2.5rem;font-family:system-ui,sans-serif;font-weight:600;background:var(--gold);color:var(--dark);text-decoration:none;padding:.75em 1.5em;border-radius:9px}
.ph{background:rgba(201,169,110,.14);border:1px dashed rgba(201,169,110,.5);border-radius:4px;padding:.05em .4em;font-family:system-ui,sans-serif;font-size:.9em;color:var(--gold-lt)}
hr{border:none;border-top:1px solid rgba(201,169,110,.2);margin:2.5rem 0}
</style>
